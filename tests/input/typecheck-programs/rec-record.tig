let
    type list = {first: int, rest: list}
    var l1 := list {first=1, rest=nil}

    type treelist = {first: tree, rest: treelist}
    type tree = {key: int, children: treelist}

    var t1 := tree {key=1, children=nil}
    var t2 := tree {key=2, children=nil}
    var children := treelist {first=t1, rest=treelist {first=t2, rest=nil}}
    var t3 := tree {key=3, children=children}

    type myInt = int
    type myInt2 = myInt
    type myArrInt = array of myInt2
    type myRecord = {field1: myInt, field2: recordArray}
    type recordArray = array of myRecord
        
in
    ()
end
