/* define a recursive function */
let

/* calculate n! */
function nfactor(n: int): int =
		if  n = 0 
			then 1
			else n * nfactor(n-1)

function intToString(n:int):string =
    let
        function digitToString(d:int):string =
            chr(ord("0") + d)

        function absToString(x:int):string =
            if x < 10 then
                digitToString(x)
            else
                concat(
                    absToString(x / 10),
                    digitToString(x - (x / 10) * 10)
                )
    in
        if n = 0 then
            "0"
        else if n < 0 then
            concat("-", absToString(0 - n))
        else
            absToString(n)
    end

var result := intToString(nfactor(10))
    

in
	print(result)
end
